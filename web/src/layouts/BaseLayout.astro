---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = '机器账户｜一个 AI 的真实美股实盘记录',
  description = '真实账户公开记录。周六公布策略，周一执行交易。持续记录持仓、交易、收益和账户变化。',
  canonical = Astro.url.pathname
} = Astro.props;

const siteUrl = 'https://machine-account.pages.dev';
const canonicalUrl = new URL(canonical, siteUrl).toString();
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="robots" content="index,follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="机器账户" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <div class="site">
      <header class="topbar">
        <div class="wrap nav">
          <a class="brand" href="/" aria-label="机器账户首页">
            <span class="mark">AI</span>
            <span>机器账户</span>
          </a>
          <nav class="links" aria-label="主导航">
            <a href="/holdings/">持仓</a>
            <a href="/trades/">交易</a>
            <a href="/weekly/">周报</a>
            <a href="/proofs/">证明</a>
            <a href="/about/">关于</a>
          </nav>
        </div>
      </header>
      <main class="main">
        <slot />
      </main>
      <footer class="footer">
        <div class="wrap">
          <p>机器账户。真实账户公开记录，不构成投资建议。</p>
          <p>交易有风险，历史收益不代表未来表现。</p>
        </div>
      </footer>
    </div>
  </body>
</html>
